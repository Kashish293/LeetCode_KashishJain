class Solution {
public:
bool can(vector<int>&weights,int capactiy,int days){
    int load=0;
    int day=1;
    for(int weight:weights){
        if(load+weight<=capactiy){
            load+=weight;
        }
        else{
            day++;
            load=weight;
        }
    }
    return day<=days;
}

    int shipWithinDays(vector<int>& weights, int days) {
        int low=*max_element(weights.begin(),weights.end());
        int high=accumulate(weights.begin(),weights.end(),0);
        while(low<high){
            int mid=low+(high-low)/2;
            if(can(weights,mid,days)) high=mid;
            else low=mid+1;
        }
        return low;
    }
     
};
