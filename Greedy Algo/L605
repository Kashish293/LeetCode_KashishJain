class Solution {
public:
    bool canPlaceFlowers(vector<int>& flowerbed, int n) {
        int n1=flowerbed.size();
        for(int i=0;i<n1;i++){
            if((i==0||flowerbed[i-1]==0)&&flowerbed[i]==0&&(i==n1-1||flowerbed[i+1]==0)){
                flowerbed[i]=1;
                n--;
            }
            if(n==0)return true;
        }
        return n<=0;

        }
    
};
