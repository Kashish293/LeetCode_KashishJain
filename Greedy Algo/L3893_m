class Solution {
public:
    int maximumTeamSize(vector<int>& startTime, vector<int>& endTime) {
        vector<pair<int,int>>intervals;
        for(int i=0;i<startTime.size();i++){
            intervals.push_back({startTime[i],endTime[i]});
        }
        int ans=0;
            sort(startTime.begin(),startTime.end());
            sort(endTime.begin(),endTime.end());
            for(auto x:intervals){
                int l=x.first;
                int r=x.second;
            
            int endbeforestart=lower_bound(endTime.begin(),endTime.end(),l)-endTime.begin();
            int startbeforeend=upper_bound(startTime.begin(),startTime.end(),r)-startTime.begin();
            ans=max(ans,startbeforeend-endbeforestart);
        }
        return ans;
    }
};
