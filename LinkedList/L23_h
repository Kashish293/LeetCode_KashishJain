class Solution {
public:
    ListNode* mergeKLists(vector<ListNode*>& lists) {
        vector<int>temp;
        for(ListNode* head:lists){
            while(head){
                temp.push_back(head->val);
                head=head->next;
            }
        }
        sort(temp.begin(),temp.end());
        ListNode* dummy=new ListNode(-1);
        ListNode* tail=dummy;
        for(int x:temp){
            tail->next=new ListNode(x);
            tail=tail->next;
        }
        return dummy->next;
    }
};
