class Solution {
public:
    bool checkAlmostEquivalent(string word1, string word2) {
        vector<int>freq1(128,0);
        for(int i=0;i<word1.size();i++){
            freq1[word1[i]]++;
        }
        vector<int>freq2(128,0);
        for(int i=0;i<word2.size();i++){
            freq2[word2[i]]++;
        }
        for(int i=0;i<128;i++){
            if(abs(freq1[i]-freq2[i])>3){
                return false;
            }
        }
        return true;
        
    }
};
