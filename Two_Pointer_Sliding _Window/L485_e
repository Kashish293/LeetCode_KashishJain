class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& nums) {
        int n=nums.size();
        
        int ones=0;
        int maxone=0;
        for(int right=0;right<n;right++){
            if(nums[right]==1) ones++;
                maxone=max(ones,maxone);
                if(nums[right]==0) ones=0;
        }
        return maxone;
    }
};
