class Solution {
public:
    int longestBeautifulSubstring(string word) {
        int left=0;
        int ans=0;
        int count=1;
        for(int right=1;right<word.size();right++){
            if(word[right]<word[right-1]) {
                    left=right;
                    count=1;
            }
            else if(word[right]>word[right-1]) count++;
            
             if(count==5) {
            ans=max(ans,right-left+1);
        }
        }
       
        return ans;
    }
};
