class Solution {
public:
    int lengthOfLongestSubstringKDistinct(string s, int k) {
     int n=s.size();
     vector<int>freq(128,0);
     int ans=0;
     int left=0;
     int count=0;
     for(int right=0;right<n;right++){
        freq[s[right]]++;
        if(freq[s[right]]==1) count++;
        while(count>k){
            if(freq[s[left]]==1)count--;
            freq[s[left]]--;
            left++;
        }
        ans=max(ans,right-left+1);
     }   
     return ans;
    }
};
